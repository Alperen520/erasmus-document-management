<%- include('partials/head', { title: 'Belge Yönetimi' }) %>
<%- include('partials/topbar') %>
<div class="container">
  <div class="flex-between" style="margin-bottom:14px">
    <a href="<%= homeUrl %>" class="btn btn-sm btn-outline">← Panel</a>
  </div>

  <h1 class="page-title">Belge Yönetimi</h1>
  <p class="page-sub">Öğrencilerin otomatik doldurup indireceği belge şablonlarını buradan yönetin.
    Word'de doldurulacak yerlere <strong>[[Alan Adı]]</strong> işareti koyun ve <strong>.docx</strong> olarak yükleyin.</p>

  <% if (err) { %><div class="alert alert-error"><%= err %></div><% } %>
  <% if (msg) { %><div class="alert alert-success"><%= msg %></div><% } %>

  <div class="card">
    <h3 style="margin-top:0">Yeni Belge Yükle</h3>
    <form method="POST" action="/belge-yonetimi/yukle" enctype="multipart/form-data">
      <div class="form-row" style="display:flex;gap:12px;flex-wrap:wrap">
        <div class="form-group" style="flex:1;min-width:200px">
          <label for="by-tur">Hareketlilik Türü</label>
          <select id="by-tur" name="tur" required>
            <% types.forEach(function (t) { %>
              <option value="<%= t %>"><%= t %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group" style="flex:1;min-width:200px">
          <label for="by-ad">Belge Adı</label>
          <input type="text" id="by-ad" name="ad" required placeholder="örn. Hibe Sözleşmesi" />
        </div>
        <div class="form-group" style="flex:1;min-width:200px">
          <label for="by-dosya">Şablon Dosyası (.docx)</label>
          <input type="file" id="by-dosya" name="dosya" accept=".docx" required />
        </div>
      </div>
      <button type="submit" class="btn">Yükle ve Alanları Göster</button>
    </form>
  </div>

  <h2 class="page-title" style="font-size:18px;margin-top:24px">Yüklü Belgeler</h2>
  <% if (!rows.length) { %>
    <div class="card text-center muted">Henüz belge şablonu yüklenmemiş.</div>
  <% } %>
  <div class="grid">
    <% rows.forEach(function (r) { %>
      <a class="card" style="margin-bottom:0;text-decoration:none;color:inherit" href="/belge-yonetimi/<%= r.id %>">
        <div style="display:flex;align-items:flex-start;gap:12px">
          <div class="module-icon" style="margin-bottom:0;flex-shrink:0">📄</div>
          <div style="min-width:0">
            <h3 style="margin:0 0 4px"><%= r.ad %></h3>
            <p class="muted" style="margin:0;font-size:13px"><%= r.tur %></p>
            <p class="muted" style="margin:4px 0 0;font-size:12px">
              <% if (r.alanSayisi === null) { %>
                ⚠️ Dosya okunamıyor
              <% } else { %>
                <%= r.alanSayisi %> doldurulacak alan
              <% } %>
            </p>
          </div>
        </div>
        <div style="margin-top:14px"><span class="btn btn-sm btn-outline">Yönet →</span></div>
      </a>
    <% }); %>
  </div>
</div>
<%- include('partials/footer') %>
