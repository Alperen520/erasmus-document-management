<%- include('partials/head', { title: 'Duyurular' }) %>
<%- include('partials/topbar') %>
<div class="container">
  <div class="flex-between" style="margin-bottom:14px">
    <a href="<%= homeUrl %>" class="btn btn-sm btn-outline">← Panel</a>
  </div>

  <h1 class="page-title">Duyurular</h1>
  <p class="page-sub">Öğrenci/personel panelinde görünecek duyuruları buradan yönetin.
    "Herkes" seçilirse tüm kullanıcılara, bir tür seçilirse yalnız o hareketlilik türündeki kullanıcılara gösterilir.</p>

  <% if (err) { %><div class="alert alert-error"><%= err %></div><% } %>
  <% if (msg) { %><div class="alert alert-success"><%= msg %></div><% } %>

  <div class="card">
    <h3 style="margin-top:0">Yeni Duyuru</h3>
    <form method="POST" action="/duyurular/ekle">
      <div class="row">
        <div class="form-group" style="flex:2 1 260px">
          <label for="d-baslik">Başlık</label>
          <input type="text" id="d-baslik" name="baslik" required
                 placeholder="örn. Hibe ödemeleri hakkında" maxlength="120" />
        </div>
        <div class="form-group" style="flex:1 1 200px">
          <label for="d-tur">Hedef Kitle</label>
          <select id="d-tur" name="tur">
            <option value="">Herkes</option>
            <% types.forEach(function (t) { %>
              <option value="<%= t %>"><%= t %></option>
            <% }); %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="d-icerik">İçerik</label>
        <textarea id="d-icerik" name="icerik" required rows="4"
                  placeholder="Duyuru metni..."></textarea>
      </div>
      <button type="submit" class="btn">📢 Yayınla</button>
    </form>
  </div>

  <h2 class="page-title" style="font-size:18px;margin-top:24px">Yayındaki Duyurular</h2>
  <% if (!rows.length) { %>
    <div class="card text-center muted">Henüz duyuru yok.</div>
  <% } %>
  <% rows.forEach(function (d) { %>
    <div class="card" style="padding:16px 20px">
      <div class="flex-between" style="align-items:flex-start">
        <div style="min-width:0">
          <div style="font-weight:600;margin-bottom:4px"><%= d.baslik %></div>
          <div class="muted" style="font-size:12px;margin-bottom:8px">
            <span class="tag"><%= d.tur || 'Herkes' %></span>
            <%= formatDateTR((d.created_at || '').slice(0, 10)) %> —
            <%= d.ekleyen_ad || d.ekleyen_eposta || 'Bilinmiyor' %>
          </div>
          <div style="font-size:14px;white-space:pre-line"><%= d.icerik %></div>
        </div>
        <form method="POST" action="/duyurular/<%= d.id %>/sil" style="flex-shrink:0"
              onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">
          <button type="submit" class="btn btn-sm btn-danger">Sil</button>
        </form>
      </div>
    </div>
  <% }); %>
</div>
<%- include('partials/footer') %>
